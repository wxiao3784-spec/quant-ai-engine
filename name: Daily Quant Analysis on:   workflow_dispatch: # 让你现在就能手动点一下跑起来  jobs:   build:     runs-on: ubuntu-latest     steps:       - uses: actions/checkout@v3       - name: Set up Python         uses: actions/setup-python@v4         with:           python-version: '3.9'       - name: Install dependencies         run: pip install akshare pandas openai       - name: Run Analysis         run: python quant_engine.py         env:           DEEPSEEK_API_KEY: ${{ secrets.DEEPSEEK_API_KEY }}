name: Daily Quant Analysis
on:
  workflow_dispatch: # 让你现在就能手动点一下跑起来

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'
      - name: Install dependencies
        run: pip install akshare pandas openai
      - name: Run Analysis
        run: python quant_engine.py
        env:
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
